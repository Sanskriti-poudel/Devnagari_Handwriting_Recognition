DEVICE=cpu
CRNN_MODEL_PATH=../kaggle_output/artifacts/best_model.pth
TRANSFORMER_MODEL_PATH=../models/trocr/checkpoints_words
DATABASE_URL=sqlite:///./ocr_results.db
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads

# Auth — override JWT_SECRET with a real random value outside of dev.
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_MINUTES=10080

# Comma-separated list of allowed CORS origins (the Vite dev server, deployed frontend, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
