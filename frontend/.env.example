# Base URL of the OCR backend (Flask app in /webapp). No trailing slash.
VITE_API_URL=http://localhost:8000

# When true, auth/history/models/health/stats are served from an in-browser
# mock (localStorage) instead of real endpoints. The Flask backend only
# implements /api/predict, /api/document and /api/random today, so this
# defaults to "true". Flip to "false" once real endpoints exist.
VITE_USE_MOCK_API=true
